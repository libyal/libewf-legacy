m4_include([package.m4])
m4_include([test_macros.at])

include_test_inputs([ewfacquirestream])

AT_TEST_HELPER_FN(
  [run_ewftools_binary],
  [path arguments],
  [Resolves and runs a ewftools binary],
  [if test -x "$abs_top_builddir/ewftools/$[]1"; then
    BINARY="$abs_top_builddir/ewftools/$[]1"
  elif test -x "$abs_top_builddir/ewftools/$[]1.exe"; then
    # Prevent wine debug messages failing the test.
    WINEDEBUG=-all

    BINARY="$abs_top_builddir/ewftools/$[]1.exe"
  else
    echo "Missing binary: $[]1"
    exit 127
  fi
  shift

  $BINARY "$[]@"
  ])

AT_TEST_HELPER_FN(
  [run_ewftools_mt_binary],
  [path arguments],
  [Resolves and runs a ewftools-mt binary],
  [if test -x "$abs_top_builddir/ewftools-mt/$[]1"; then
    BINARY="$abs_top_builddir/ewftools-mt/$[]1"
  elif test -x "$abs_top_builddir/ewftools-mt/$[]1.exe"; then
    # Prevent wine debug messages failing the test.
    WINEDEBUG=-all

    BINARY="$abs_top_builddir/ewftools-mt/$[]1.exe"
  else
    echo "Missing binary: $[]1"
    exit 127
  fi
  shift

  $BINARY "$[]@"
  ])

AT_TEST_HELPER_FN(
  [run_ewfacquirestream_mt_and_verify_file],
  [test_profile options_set arguments test_file],
  [Runs ewfacquirestream and verifies the resulting files with ewfverify],
  [TEST_PROFILE="$[]1"
  shift
  OPTION_SET="$[]1"
  shift

  ath_fn_run_ewftools_mt_binary ewfacquirestream -CCase -DDescription -EEvidence -eExaminer -mremovable -Mlogical -NNotes -q -tacquirestream "$[]@" - > /dev/null
  STATUS=$?

  if test ${STATUS} -eq 0; then
    ath_fn_run_ewftools_binary ewfverify -q acquirestream.*01 > /dev/null
    STATUS=$?
  fi
  return $STATUS
  ])

dnl Runs ewfacquirestream on a disk/volume image and verifies the resulting files with ewfverify
dnl Arguments:
dnl   test_profile
dnl   test_options
dnl   test_inputs
m4_define([RUN_WRITE_TEST_EWFACQUIRESTREAM_MT],
  [m4_foreach_w(
    [test_input],
    [$3],
    [m4_define([option_set], m4_normalize(get_test_input_value([test_input], 1)))
    m4_define([test_options], m4_normalize(get_test_input_value([test_input], 2)))
    m4_define([test_file], [_strip(get_test_input_value([test_input], 3))])

    m4_ifblank(option_set, m4_define([option_set], [.]))

    m4_define([sanitized_test_file],
      [m4_translit([test_file], [[],[],[]"'`\], [______])])

    dnl Test with different output formats. Note that encase5 is tested next.
    m4_foreach_w(
      [format],
      [encase2 encase3 encase4 encase6 ewfx ftk linen5 linen6],
      [m4_define([ewfacquirestream_options], m4_normalize($2 test_options -cempty-block -f[]format))

      AT_SETUP(acquirestream-mt with options: 'ewfacquirestream_options' and input: 'sanitized_test_file')

      AT_SKIP_IF(
        [test -n "${SKIP_TOOLS_TESTS}" || test -n "${SKIP_TOOLS_END_TO_END_TESTS}"])

      TEST_FILE=`ath_fn_resolve_test_file "$abs_srcdir/input/[]test_file"`

      AT_CHECK(ath_fn_run_ewfacquirestream_mt_and_verify_file $1 "option_set" ewfacquirestream_options < "${TEST_FILE}")

      AT_CLEANUP])

    dnl Test various options with encase5.
    m4_foreach_w(
      [format],
      [encase5],
      [dnl Test with different compression levels.
      m4_foreach_w(
        [compression_level],
        [empty-block fast best],
        [m4_define([ewfacquirestream_options], m4_normalize($2 test_options -c[]compression_level -f[]format))

        AT_SETUP(acquirestream-mt with options: 'ewfacquirestream_options' and input: 'sanitized_test_file')

        AT_SKIP_IF(
          [test -n "${SKIP_TOOLS_TESTS}" || test -n "${SKIP_TOOLS_END_TO_END_TESTS}"])

        TEST_FILE=`ath_fn_resolve_test_file "$abs_srcdir/input/[]test_file"`

        AT_CHECK(ath_fn_run_ewfacquirestream_mt_and_verify_file $1 "option_set" ewfacquirestream_options < "${TEST_FILE}")

        AT_CLEANUP])

      dnl Test with different block sizes.
      m4_foreach_w(
        [block_size],
        [16 32 64 128 256 512 1024 2048 4096 8192 16384 32768],
        [m4_define([ewfacquirestream_options], m4_normalize($2 test_options -b[]block_size -cempty-block -f[]format))

        AT_SETUP(acquirestream-mt with options: 'ewfacquirestream_options' and input: 'sanitized_test_file')

        AT_SKIP_IF(
          [test -n "${SKIP_TOOLS_TESTS}" || test -n "${SKIP_TOOLS_END_TO_END_TESTS}"])

        TEST_FILE=`ath_fn_resolve_test_file "$abs_srcdir/input/[]test_file"`

        AT_CHECK(ath_fn_run_ewfacquirestream_mt_and_verify_file $1 "option_set" ewfacquirestream_options < "${TEST_FILE}")

        AT_CLEANUP])
      ])

    dnl Test with different digest hasher. Note that md5 is the default.
    m4_foreach_w(
      [digest_hash],
      [sha1 sha256],
      [m4_define([ewfacquirestream_options], m4_normalize($2 test_options -cempty-block -d[]digest_hash -fencase5))

      AT_SETUP(acquirestream-mt with options: 'ewfacquirestream_options' and input: 'sanitized_test_file')

      AT_SKIP_IF(
        [test -n "${SKIP_TOOLS_TESTS}" || test -n "${SKIP_TOOLS_END_TO_END_TESTS}"])

      TEST_FILE=`ath_fn_resolve_test_file "$abs_srcdir/input/[]test_file"`

      AT_CHECK(ath_fn_run_ewfacquirestream_mt_and_verify_file $1 "option_set" ewfacquirestream_options < "${TEST_FILE}")

      AT_CLEANUP])
    ])
  ])

dnl Wrap m4_define to overwrite AT_TESTSUITE_NAME
m4_define([_M4_DEFINE_HOOK], m4_defn([m4_define]))
m4_define([m4_define],
  [m4_if(
    [$1],
    [AT_TESTSUITE_NAME],
    [_M4_DEFINE_HOOK([$1], [Running tools tests])],
    [_M4_DEFINE_HOOK([$1], [$2])])])

dnl Redefine AS_BOX to remove the "box"
m4_undefine([AS_BOX])
m4_define([AS_BOX], [echo "$1"])

AT_INIT([tools])
AT_COLOR_TESTS

dnl Rewrite AT_SETUP to change the minimum line length
m4_define([AT_SETUP],
  m4_unquote(
    [m4_bpatsubst(
      m4_dquote(m4_defn([AT_SETUP])),
      [47],
      [72])
    ])
  )

SETUP_HELPER_FUNCTIONS

RUN_WRITE_TEST_EWFACQUIRESTREAM_MT(
  [ewfacquirestream],
  [],
  test_inputs_ewfacquirestream)
